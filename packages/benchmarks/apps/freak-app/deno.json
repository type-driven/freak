{
  "name": "@fresh/benchmark-freak-app",
  "version": "0.1.0",
  "imports": {
    "@fresh/core": "../../../fresh/src/mod.ts",
    "@fresh/core/dev": "../../../fresh/src/dev/mod.ts",
    "@fresh/core/runtime": "../../../fresh/src/runtime/shared.ts",
    "@fresh/core/effect": "../../../fresh/src/effect/mod.ts",
    "@fresh/core/effect/island": "../../../fresh/src/effect/island.ts",
    "@fresh/core/effect/island-atoms": "../../../fresh/src/effect/island-atoms.ts",
    "effect": "npm:effect@^4.0.0-beta.20",
    "effect/Schema": "npm:effect@^4.0.0-beta.20/Schema",
    "effect/unstable/reactivity/Atom": "npm:effect@^4.0.0-beta.20/unstable/reactivity/Atom",
    "@effect/platform-browser": "npm:@effect/platform-browser@4.0.0-beta.13",
    "preact": "npm:preact@^10.28.3",
    "preact/hooks": "npm:preact@^10.28.3/hooks"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "deno.ns", "deno.unstable"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "tasks": {
    "dev": "deno run -A --watch dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno serve -A _fresh/server.js"
  }
}
