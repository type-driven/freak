{
  "name": "@fresh/benchmark-upstream-app",
  "version": "0.1.0",
  "imports": {
    "@fresh/core": "jsr:@fresh/core@2.2.0",
    "@fresh/core/dev": "jsr:@fresh/core@2.2.0/dev",
    "@fresh/core/runtime": "jsr:@fresh/core@2.2.0/runtime",
    "fresh/internal": "jsr:@fresh/core@2.2.0/internal",
    "preact": "npm:preact@^10.28.3",
    "preact/hooks": "npm:preact@^10.28.3/hooks"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "deno.ns", "deno.unstable"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "tasks": {
    "dev": "deno run -A --watch dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno serve -A _fresh/server.js"
  }
}
